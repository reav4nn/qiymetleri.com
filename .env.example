# ============================================
# qiymetleri.com — Environment Variables
# ============================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================

# --- Database ---
POSTGRES_USER=qiymetleri
POSTGRES_PASSWORD=qiymetleri_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=qiymetleri

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- BrightData Proxy ---
# Set PROXY_ENABLED=true to route scraper traffic through BrightData.
# Sign up: https://brightdata.com → Create a "Residential Proxy" zone.
#
# Username format: brd-customer-CUSTOMER_ID-zone-ZONE_NAME
# Example: brd-customer-hl_12345678-zone-residential_proxy1
#
PROXY_ENABLED=false
PROXY_HOST=brd.superproxy.io
PROXY_PORT=22225
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_COUNTRY=az
