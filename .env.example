# ============================================
# qiymetleri.com — Environment Variables
# ============================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY: Never commit .env with real credentials.
# Variables marked (REQUIRED) will cause docker-compose to fail if unset.
# ============================================

# --- Database ---
POSTGRES_USER=qiymetleri
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=qiymetleri

# --- Redis ---
# For local Docker: set REDIS_PASSWORD (used by docker-compose).
# For managed Redis (Upstash): set REDIS_URL instead.
REDIS_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
# REDIS_URL=rediss://default:TOKEN@host:6379

# --- Admin API Credentials ---
# Used for HTTP Basic Auth on /api/v1/admin/* endpoints.
# REQUIRED: docker-compose will refuse to start with unset values.
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- BrightData Proxy ---
# Set PROXY_ENABLED=true to route scraper traffic through BrightData.
# Sign up: https://brightdata.com → Create a "Residential Proxy" zone.
#
# Username format: brd-customer-CUSTOMER_ID-zone-ZONE_NAME
# Example: brd-customer-hl_12345678-zone-residential_proxy1
#
PROXY_ENABLED=false
PROXY_HOST=brd.superproxy.io
PROXY_PORT=22225
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_COUNTRY=az

# --- Google AdSense ---
# Sign up: https://adsense.google.com → Get publisher ID and ad slot IDs.
# Publisher ID format: ca-pub-XXXXXXXXXXXXXXXX
# Ad slots are created in AdSense dashboard → Ads → By ad unit.
#
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_AD_SLOT_HOME=
NEXT_PUBLIC_AD_SLOT_SEARCH=
NEXT_PUBLIC_AD_SLOT_PRODUCT=
